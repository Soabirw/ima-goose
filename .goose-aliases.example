# IMA Goose workflow aliases — shell functions for the WordPress dev cycle
#
# SETUP
# ─────
# 1. Run the installer first (copies recipes to ~/.config/goose/recipes/):
#      node /path/to/ima-goose/scripts/install.ts
#
# 2. Copy this file to your home directory:
#      cp .goose-aliases.example ~/.goose-aliases
#
# 3. Add this line to your ~/.bashrc (or ~/.zshrc):
#      [ -f "$HOME/.goose-aliases" ] && source "$HOME/.goose-aliases"
#
# 4. Reload your shell:
#      source ~/.bashrc
#
# 5. Verify it works:
#      goose-help
#
# UPDATING
# ────────
# When recipes change, re-run install.ts to refresh ~/.config/goose/recipes/.
# When profile thinking effort/runtime env changes, copy or merge this file to
# ~/.goose-aliases again. chatgpt_codex uses alias-scoped GOOSE_THINKING_EFFORT.

# Opt-in: inject the Practitioner persona into every Goose turn.
# Uncomment to enable globally (applies to ALL goose sessions, not just IMA recipes).
# export GOOSE_MOIM_MESSAGE_FILE="$HOME/IMA/dev/ima-goose/moim/ima-practitioner.md"


# Profile runtime env helpers. codex-acp encodes effort in the model ID;
# chatgpt_codex reads GOOSE_THINKING_EFFORT from the command environment.
# These scoped prefixes are harmless for providers that ignore the variable.
_goose_high() { GOOSE_THINKING_EFFORT=high goose "$@"; }
_goose_mid() { GOOSE_THINKING_EFFORT=medium goose "$@"; }
_goose_low() { GOOSE_THINKING_EFFORT=low goose "$@"; }

# Goose Desktop tier wrappers. The .desktop Exec field may show
# "/usr/lib/goose/Goose %U"; in shell, call the binary and pass URLs/files as args.
_goose_desktop_high() { GOOSE_THINKING_EFFORT=high "/usr/lib/goose/Goose" "$@"; }
_goose_desktop_mid() { GOOSE_THINKING_EFFORT=medium "/usr/lib/goose/Goose" "$@"; }
_goose_desktop_low() { GOOSE_THINKING_EFFORT=low "/usr/lib/goose/Goose" "$@"; }

goose-desktop-high() { _goose_desktop_high "$@"; }
goose-desktop-mid() { _goose_desktop_mid "$@"; }
goose-desktop-low() { _goose_desktop_low "$@"; }

# ── HITL Cycle Helper: Taskwarrior → Plan → Implement → Test → Review → Learn ─
# Installed by scripts/install.ts as ~/.local/bin/goose-cycle.
# Usage:
#   goose-cycle start --project ima-mcp-gateway
#   goose-cycle status --project ima-mcp-gateway --task S01
#   goose-cycle close --project ima-mcp-gateway --task S01
#
# Legacy umbrella recipe remains available for explicit experiments:
goose-cycle-umbrella() {
  local source="${1:-}"
  if [ -n "$source" ]; then
    _goose_high run --recipe software-development-cycle \
      --params "source=${source}" \
      --params "mode=guided" \
      --params "scope=feature" \
      --name "cycle-umbrella-$(date +%Y%m%d-%H%M)" \
      --interactive
  else
    _goose_high run --recipe software-development-cycle --name "cycle-umbrella-$(date +%Y%m%d-%H%M)" --interactive
  fi
}

# ── Phase 1: Brainstorm ───────────────────────────────────────────────────────
# Interactive brainstorming session. Researches memories/code/web, iterates Q&A
# until you signal satisfaction, saves to Serena memory or a file.
# Usage: goose-brainstorm                    (open-ended; greets and asks)
#        goose-brainstorm "auth refactor idea ..."
#        goose-brainstorm FNR-123
goose-brainstorm() {
  local seed="${1:-}"
  if [ -n "$seed" ]; then
    _goose_high run --recipe brainstorm --params "idea=${seed}" --name "brainstorm-$(date +%Y%m%d)" --interactive
  else
    _goose_high run --recipe brainstorm --name "brainstorm-$(date +%Y%m%d)" --interactive
  fi
}

# ── Phase 2: Technical Plan ───────────────────────────────────────────────────
# Interactive technical-planning session. Researches the codebase + memories +
# library docs, iterates Q&A on implementation specifics, saves to Serena or a
# file. Does NOT require a brainstorm to exist first — accepts raw idea, Serena
# memory name, file path, or Jira key. Save the result, then feed it to
# task-planner (Epic→Story→Task) or implement directly.
# Usage: goose-plan                                     (open-ended; greets and asks)
#        goose-plan "<serena-memory-name>"              (e.g. a brainstorm)
#        goose-plan FNR-123
#        goose-plan "raw idea text..."
goose-plan() {
  local spec=""
  local project=""
  local task=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --project) project="${2:?Usage: goose-plan [spec] [--project <project> --task <task>]}"; shift 2 ;;
      --task) task="${2:?Usage: goose-plan [spec] [--project <project> --task <task>]}"; shift 2 ;;
      *) spec="$1"; shift ;;
    esac
  done

  local args=(run --recipe plan --name "plan-$(date +%Y%m%d)" --interactive)
  [ -n "$spec" ] && args+=(--params "spec=${spec}")
  [ -n "$project" ] && args+=(--params "project=${project}")
  [ -n "$task" ] && args+=(--params "task=${task}")
  _goose_high "${args[@]}"
}

# ── Product Requirements: Task Planning ───────────────────────────────────────
# Use after brainstorm/PRD shaping to decompose requirements into Epic→Story→Task
# artifacts. For per-story implementation, prefer goose-plan first unless the
# story is large enough to need localized decomposition.
# Usage: goose-orchestrate
#        goose-orchestrate "<brainstorm-memory-name>"
#        goose-orchestrate FNR-123
goose-orchestrate() {
  local key="${1:-}"
  if [ -n "$key" ]; then
    _goose_high run --recipe task-planner --params "architecture_spec=${key}" --name "task-plan-$(date +%Y%m%d)" --interactive
  else
    _goose_high run --recipe task-planner --name "task-plan-$(date +%Y%m%d)" --interactive
  fi
}

# ── Phase 3a: Story → Implementation Prompt ───────────────────────────────────
# Usage: goose-story-prompt FNR-123
goose-story-prompt() {
  local key="${1:?Usage: goose-story-prompt FNR-123}"
  _goose_high run --recipe prompt-starter --params "idea=${key}" --name "story-${key}-prompt" --interactive
}

# ── Phase 3b: Implement a Story ───────────────────────────────────────────────
# Usage: goose-implement
#        goose-implement FNR-123
goose-implement() {
  local key=""
  local project=""
  local task=""
  local cycle_phase=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --project) project="${2:?Usage: goose-implement [source] [--project <project> --task <task>] [--cycle-phase resolve-review]}"; shift 2 ;;
      --task) task="${2:?Usage: goose-implement [source] [--project <project> --task <task>] [--cycle-phase resolve-review]}"; shift 2 ;;
      --cycle-phase) cycle_phase="${2:?Usage: goose-implement [source] [--project <project> --task <task>] [--cycle-phase resolve-review]}"; shift 2 ;;
      *) key="$1"; shift ;;
    esac
  done

  local name_slug="${key:-${task:-$(date +%Y%m%d-%H%M)}}"
  local args=(run --recipe wp-developer --name "story-${name_slug}-impl" --interactive)
  [ -n "$key" ] && args+=(--params "plan_source=${key}")
  [ -n "$project" ] && args+=(--params "project=${project}")
  [ -n "$task" ] && args+=(--params "task=${task}")
  [ -n "$cycle_phase" ] && args+=(--params "cycle_phase=${cycle_phase}")
  _goose_mid "${args[@]}"
}

# ── Phase 4: Code Review ──────────────────────────────────────────────────────
# Three modes (recipe auto-detects from opener):
#   1. Full review     — pass a PR URL or FNR-### key
#   2. Prompt only     — open interactively, say "create review prompt for <URL>"
#   3. Pre-built spec  — open interactively, paste a `## Goal / ## Scope / ## Review focus` block
#
# Usage:
#   goose-review                                          # greets, asks which mode
#   goose-review FNR-123                                  # Mode 1, full review
#   goose-review https://git.example/owner/repo/pulls/45  # Mode 1, full review
goose-review() {
  local target=""
  local project=""
  local task=""
  local cycle_phase=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --project) project="${2:?Usage: goose-review [target] [--project <project> --task <task>] [--cycle-phase rereview]}"; shift 2 ;;
      --task) task="${2:?Usage: goose-review [target] [--project <project> --task <task>] [--cycle-phase rereview]}"; shift 2 ;;
      --cycle-phase) cycle_phase="${2:?Usage: goose-review [target] [--project <project> --task <task>] [--cycle-phase rereview]}"; shift 2 ;;
      *) target="$1"; shift ;;
    esac
  done

  local slug
  local args=(run --recipe code-review)
  if [ -n "$target" ]; then
    # Build a filesystem-safe session-name slug from the target (PR URL or FNR key).
    slug=$(echo "$target" | tr -c 'A-Za-z0-9-' '-' | sed -E 's/-+/-/g; s/^-|-$//g' | cut -c1-40)
    args+=(--params "target=${target}" --name "review-${slug}-$(date +%Y%m%d-%H%M)" --interactive)
  else
    args+=(--name "review-$(date +%Y%m%d-%H%M)" --interactive)
  fi
  [ -n "$project" ] && args+=(--params "project=${project}")
  [ -n "$task" ] && args+=(--params "task=${task}")
  [ -n "$cycle_phase" ] && args+=(--params "cycle_phase=${cycle_phase}")
  _goose_high "${args[@]}"
}

# ── Phase 4b: Adversarial Code Review ─────────────────────────────────────────
# Runs a dual-model review: Claude Opus and GPT-5.5 attack the same brief.
#
# Usage:
#   goose-adversarial-review                                          # greets, asks for target
#   goose-adversarial-review FNR-123
#   goose-adversarial-review https://git.example/owner/repo/pulls/45
goose-adversarial-review() {
  local target="${1:-}"
  local slug
  if [ -n "$target" ]; then
    slug=$(echo "$target" | tr -c 'A-Za-z0-9-' '-' | sed -E 's/-+/-/g; s/^-|-$//g' | cut -c1-40)
    _goose_high run --recipe adversarial-review --params "target=${target}" --name "adversarial-review-${slug}-$(date +%Y%m%d-%H%M)" --interactive
  else
    _goose_high run --recipe adversarial-review --name "adversarial-review-$(date +%Y%m%d-%H%M)" --interactive
  fi
}

# ── Phase 5: Document/Learn ──────────────────────────────────────────────────
# Close out completed work by updating docs and routing durable learning to
# Serena, Vestige, and Qdrant.
# Usage: goose-learn
#        goose-learn "artifact bundle"
#        goose-learn "artifact bundle" feature
#        goose-learn "artifact bundle" story --project ima-mcp-gateway --task S01
goose-learn() {
  local artifact_bundle=""
  local update_scope="story"
  local project=""
  local task=""
  local positional=()

  while [ $# -gt 0 ]; do
    case "$1" in
      --project) project="${2:?Usage: goose-learn [artifact] [story|feature|release] [--project <project> --task <task>]}"; shift 2 ;;
      --task) task="${2:?Usage: goose-learn [artifact] [story|feature|release] [--project <project> --task <task>]}"; shift 2 ;;
      *) positional+=("$1"); shift ;;
    esac
  done

  artifact_bundle="${positional[0]:-}"
  update_scope="${positional[1]:-story}"

  case "$update_scope" in
    story|feature|release) ;;
    *)
      echo "Usage: goose-learn [artifact-bundle] [story|feature|release]" >&2
      return 2
      ;;
  esac

  local args=(run --recipe document-learn --params "update_scope=${update_scope}" --name "learn-${update_scope}-$(date +%Y%m%d-%H%M)" --interactive)
  [ -n "$artifact_bundle" ] && args+=(--params "artifact_bundle=${artifact_bundle}")
  [ -n "$project" ] && args+=(--params "project=${project}")
  [ -n "$task" ] && args+=(--params "task=${task}")
  _goose_mid "${args[@]}"
}

# ── Model Profile Switcher ────────────────────────────────────────────────────
# Switch which provider's models the recipes use by re-running the installer
# with a different profile. See docs/MODEL-TIERS.md for the tier mapping.
#
# Profiles:
#   chatgpt_codex — Default. Native ChatGPT Codex provider. HIGH/MID/LOW → GPT-5.5.
#   openai        — codex-acp fallback via ChatGPT Pro/Max. HIGH/MID/LOW → GPT-5.5 efforts.
#   hybrid        — HIGH via codex-acp, MID/LOW via claude-acp.
#   anthropic     — Direct Anthropic API. HIGH/MID/LOW → full claude-* model IDs.
#   claude-acp    — Claude friendly shortnames, if working locally.
#
# Switching profiles only rewrites recipes. You also need to update
# ~/.config/goose/config.yaml GOOSE_PROVIDER and auth env vars for the new provider.
#
# Usage:
#   goose-profile                  (shows current; lists available)
#   goose-profile chatgpt_codex
#   goose-profile openai
#   goose-profile hybrid
#   goose-profile anthropic
#   goose-profile claude-acp
goose-profile() {
  local profile="${1:-}"
  local script="$HOME/IMA/dev/ima-goose/scripts/install.ts"
  if [ -z "$profile" ]; then
    echo "Available profiles: chatgpt_codex (default), openai, hybrid, anthropic, claude-acp"
    echo "Deployed recipes (first 5):"
    grep -h "^  goose_model:" "$HOME/.config/goose/recipes/"*.yaml 2>/dev/null | sort -u | head -5
    return 0
  fi
  node "$script" --profile "$profile"
  echo "Reminder: copy or merge .goose-aliases.example to ~/.goose-aliases when profile thinking effort/runtime env changes."
}

# ── Session Management ────────────────────────────────────────────────────────
goose-resume() {
  local name="${1:?Usage: goose-resume <session-name>}"
  goose run --resume --name "$name"
}

goose-sessions() {
  goose session list
}

# ── Direct Recipe Shortcuts ───────────────────────────────────────────────────

goose-wp() {
  _goose_mid run --recipe wp-developer --params "environment=ddev" --name "wp-$(date +%Y%m%d-%H%M)" --interactive
}

goose-js() {
  _goose_mid run --recipe js-developer --name "js-$(date +%Y%m%d-%H%M)" --interactive
}

goose-ui() {
  _goose_high run --recipe ui-ux-designer --name "ui-ux-$(date +%Y%m%d-%H%M)" --interactive
}

goose-design-to-code() {
  local source="${1:-}"
  if [ -n "$source" ]; then
    _goose_high run --recipe design-to-code \
      --params "source=${source}" \
      --name "design-to-code-$(date +%Y%m%d-%H%M)" \
      --interactive
  else
    _goose_high run --recipe design-to-code --name "design-to-code-$(date +%Y%m%d-%H%M)" --interactive
  fi
}

goose-investigate() {
  local source="${1:-}"
  if [ -n "$source" ]; then
    _goose_high run --recipe investigate \
      --params "source=${source}" \
      --name "investigate-$(date +%Y%m%d-%H%M)" \
      --interactive
  else
    _goose_high run --recipe investigate --name "investigate-$(date +%Y%m%d-%H%M)" --interactive
  fi
}

goose-explore() {
  _goose_low run --recipe explore --name "explore-$(date +%Y%m%d-%H%M)" --interactive
}

goose-tests() {
  local test_source=""
  local project=""
  local task=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --project) project="${2:?Usage: goose-tests [source] [--project <project> --task <task>]}"; shift 2 ;;
      --task) task="${2:?Usage: goose-tests [source] [--project <project> --task <task>]}"; shift 2 ;;
      *) test_source="$1"; shift ;;
    esac
  done

  local args=(run --recipe test-writer --name "tests-$(date +%Y%m%d-%H%M)" --interactive)
  [ -n "$test_source" ] && args+=(--params "test_source=${test_source}")
  [ -n "$project" ] && args+=(--params "project=${project}")
  [ -n "$task" ] && args+=(--params "task=${task}")
  _goose_mid "${args[@]}"
}

goose-scorecard() {
  local target="${1:-}"
  if [ -n "$target" ]; then
    _goose_high run --recipe scorecard \
      --params "target=${target}" \
      --name "scorecard-$(date +%Y%m%d-%H%M)" \
      --interactive
  else
    _goose_high run --recipe scorecard --name "scorecard-$(date +%Y%m%d-%H%M)" --interactive
  fi
}

# Usage: goose-ship-it stg [project-path]
#        goose-ship-it prod [project-path]
goose-ship-it() {
  local env="${1:?Usage: goose-ship-it stg|prod [project-path]}"
  local project_path="${2:-$(pwd)}"

  case "$env" in
    stg|prod) ;;
    *)
      echo "Usage: goose-ship-it stg|prod [project-path]" >&2
      return 2
      ;;
  esac

  _goose_mid run --recipe goose-ship-it \
    --params "target_env=${env}" \
    --params "project_path=${project_path}" \
    --name "ship-it-${env}-$(date +%Y%m%d-%H%M)"
}

# Usage: goose-patristic
#        goose-patristic "What does Irenaeus teach about recapitulation?"
goose-patristic() {
  local question="${1:-}"
  if [ -n "$question" ]; then
    _goose_high run --recipe patristic-researcher \
      --params "question=${question}" \
      --name "patristic-$(date +%Y%m%d-%H%M)" \
      --interactive
  else
    _goose_high run --recipe patristic-researcher --name "patristic-$(date +%Y%m%d-%H%M)" --interactive
  fi
}

# Usage: goose-ima-research
#        goose-ima-research "What is the evidence for metformin and Long COVID prevention?"
goose-ima-research() {
  local question="${1:-}"
  if [ -n "$question" ]; then
    _goose_high run --recipe ima-researcher \
      --params "question=${question}" \
      --name "ima-research-$(date +%Y%m%d-%H%M)" \
      --interactive
  else
    _goose_high run --recipe ima-researcher --name "ima-research-$(date +%Y%m%d-%H%M)" --interactive
  fi
}

# ── Help ──────────────────────────────────────────────────────────────────────
goose-help() {
  cat <<'EOF'
IMA Goose Workflow Commands
────────────────────────────────────────────────────────
RECOMMENDED HITL WORKFLOWS:

  Product requirements:
    goose-brainstorm [seed]       Concept/new site/large feature → PRD draft
    goose-orchestrate [source]    PRD/brainstorm → Epic→Story→Task requirements
    goose-learn [artifact] feature
                                  Document approved PRD + story map

  Per-story delivery:
    goose-plan [story]            Story → detailed implementation plan
    goose-implement [source]      Approved plan/story → implementation
    goose-tests                   Write or debug tests
    goose-review [FNR-123]        PR review, comment, Jira update
    goose-learn [artifact] story  Document story closeout

EXPERIMENTAL:

  goose-cycle start --project P
                                Taskwarrior/Vestige-backed HITL cycle helper
  goose-cycle-umbrella [source] Experimental umbrella recipe
  goose-story-prompt FNR-123    Jira story → implementation prompt (legacy)
  goose-adversarial-review [target]
                                Experimental Anthropic + GPT-5.5 adversarial review

SESSION MANAGEMENT:

  goose-resume <session-name>   Resume a named session
  goose-sessions                List all sessions

DIRECT RECIPES:

  goose-wp                      WordPress development (ad hoc)
  goose-js                      JavaScript/TypeScript development (Svelte, Node, APIs, CLIs, TUIs)
  goose-ui                      UI/UX review with Chrome DevTools + Bootstrap/IMA CSS guidance
  goose-design-to-code [source] Design/screenshot → implementation prompt or code pipeline
  goose-investigate [source]    Sherlock-style read-only troubleshooting/root-cause investigation
  goose-explore                 Read-only codebase exploration
  goose-tests                   Write or debug tests
  goose-scorecard [target]      Project, PR, or codebase quality scorecard
  goose-ship-it stg|prod        Prepare IMA ship-it release branches/tags
  goose-ima-research [question] IMA medical research with ima-research + primary-source verification
  goose-patristic [question]    Patristic research with Qdrant theology + primary-source verification

UPDATING RECIPES:

  node ~/IMA/dev/ima-goose/scripts/install.ts   Re-sync after pulling updates
  goose-profile                                 Show available model profiles
  goose-profile chatgpt_codex                   Switch recipes to default native ChatGPT Codex provider
  goose-profile openai                          Switch recipes to codex-acp fallback GPT-5.5 profile
  goose-profile hybrid                          Switch HIGH to GPT-5.5, MID/LOW to Claude ACP
  goose-profile claude-acp                      Switch recipes to Claude ACP shortnames

DOCS:

  ~/IMA/dev/ima-goose/docs/WORKFLOW-MAPPING.md  — Full workflow guide
  ~/IMA/dev/ima-goose/shared/tool-guides/tea.md — Gitea CLI reference
────────────────────────────────────────────────────────
EOF
}
