# IMA Goose workflow aliases — shell functions for the WordPress dev cycle
#
# SETUP
# ─────
# 1. Run the installer first (copies recipes to ~/.config/goose/recipes/):
#      node /path/to/ima-goose/scripts/install.ts
#
# 2. Copy this file to your home directory:
#      cp .goose-aliases.example ~/.goose-aliases
#
# 3. Add this line to your ~/.bashrc (or ~/.zshrc):
#      [ -f "$HOME/.goose-aliases" ] && source "$HOME/.goose-aliases"
#
# 4. Reload your shell:
#      source ~/.bashrc
#
# 5. Verify it works:
#      goose-help
#
# UPDATING
# ────────
# When recipes change, re-run install.ts to refresh ~/.config/goose/recipes/.

# Opt-in: inject the Practitioner persona into every Goose turn.
# Uncomment to enable globally (applies to ALL goose sessions, not just IMA recipes).
# export GOOSE_MOIM_MESSAGE_FILE="$HOME/IMA/dev/ima-goose/moim/ima-practitioner.md"

# ── Full Cycle: Brainstorm → Plan → Implement → Test → Review → Document/Learn ─
# Preferred umbrella for the complete IMA software development cycle. Pass a
# raw idea, Serena memory, file path, Jira key, existing plan, or story spec.
# Usage: goose-cycle
#        goose-cycle "goose-software-development-cycle-technical-plan"
goose-cycle() {
  local source="${1:-}"
  if [ -n "$source" ]; then
    goose run --recipe software-development-cycle \
      --params "source=${source}" \
      --params "mode=guided" \
      --params "scope=feature" \
      --name "cycle-$(date +%Y%m%d-%H%M)" \
      --interactive
  else
    goose run --recipe software-development-cycle --name "cycle-$(date +%Y%m%d-%H%M)" --interactive
  fi
}

# ── Phase 1: Brainstorm ───────────────────────────────────────────────────────
# Interactive brainstorming session. Researches memories/code/web, iterates Q&A
# until you signal satisfaction, saves to Serena memory or a file.
# Usage: goose-brainstorm                    (open-ended; greets and asks)
#        goose-brainstorm "auth refactor idea ..."
#        goose-brainstorm FNR-123
goose-brainstorm() {
  local seed="${1:-}"
  if [ -n "$seed" ]; then
    goose run --recipe brainstorm --params "idea=${seed}" --name "brainstorm-$(date +%Y%m%d)" --interactive
  else
    goose run --recipe brainstorm --name "brainstorm-$(date +%Y%m%d)" --interactive
  fi
}

# ── Phase 2: Technical Plan ───────────────────────────────────────────────────
# Interactive technical-planning session. Researches the codebase + memories +
# library docs, iterates Q&A on implementation specifics, saves to Serena or a
# file. Does NOT require a brainstorm to exist first — accepts raw idea, Serena
# memory name, file path, or Jira key. Save the result, then feed it to
# task-planner (Epic→Story→Task) or implement directly.
# Usage: goose-plan                                     (open-ended; greets and asks)
#        goose-plan "<serena-memory-name>"              (e.g. a brainstorm)
#        goose-plan FNR-123
#        goose-plan "raw idea text..."
goose-plan() {
  local spec="${1:-}"
  if [ -n "$spec" ]; then
    goose run --recipe plan --params "spec=${spec}" --name "plan-$(date +%Y%m%d)" --interactive
  else
    goose run --recipe plan --name "plan-$(date +%Y%m%d)" --interactive
  fi
}

# ── Phase 2b: Orchestrate (task-master) ───────────────────────────────────────
# Drop into task-master orchestration — the previous home of `goose-plan`.
# Use when you have a saved plan and want Epic→Story→Task decomposition + Jira
# creation + sub-recipe delegation under one roof.
# Usage: goose-orchestrate
#        goose-orchestrate FNR-123
goose-orchestrate() {
  local key="${1:-}"
  if [ -n "$key" ]; then
    goose run --recipe task-master --params "task_or_jira_key=${key}" --name "orchestrate-$(date +%Y%m%d)" --interactive
  else
    goose run --recipe task-master --name "orchestrate-$(date +%Y%m%d)" --interactive
  fi
}

# ── Phase 3a: Story → Implementation Prompt ───────────────────────────────────
# Usage: goose-story-prompt FNR-123
goose-story-prompt() {
  local key="${1:?Usage: goose-story-prompt FNR-123}"
  goose run --recipe prompt-starter --params "idea=${key}" --name "story-${key}-prompt" --interactive
}

# ── Phase 3b: Implement a Story ───────────────────────────────────────────────
# Usage: goose-implement FNR-123
goose-implement() {
  local key="${1:?Usage: goose-implement FNR-123}"
  goose run --recipe task-master --params "task_or_jira_key=${key}" --name "story-${key}-impl" --interactive
}

# ── Phase 4: Code Review ──────────────────────────────────────────────────────
# Three modes (recipe auto-detects from opener):
#   1. Full review     — pass a PR URL or FNR-### key
#   2. Prompt only     — open interactively, say "create review prompt for <URL>"
#   3. Pre-built spec  — open interactively, paste a `## Goal / ## Scope / ## Review focus` block
#
# Usage:
#   goose-review                                          # greets, asks which mode
#   goose-review FNR-123                                  # Mode 1, full review
#   goose-review https://git.example/owner/repo/pulls/45  # Mode 1, full review
goose-review() {
  local target="${1:-}"
  local slug
  if [ -n "$target" ]; then
    # Build a filesystem-safe session-name slug from the target (PR URL or FNR key).
    slug=$(echo "$target" | tr -c 'A-Za-z0-9-' '-' | sed -E 's/-+/-/g; s/^-|-$//g' | cut -c1-40)
    goose run --recipe code-review --params "target=${target}" --name "review-${slug}-$(date +%Y%m%d-%H%M)" --interactive
  else
    goose run --recipe code-review --name "review-$(date +%Y%m%d-%H%M)" --interactive
  fi
}

# ── Model Profile Switcher ────────────────────────────────────────────────────
# Switch which provider's models the recipes use by re-running the installer
# with a different profile. See docs/MODEL-TIERS.md for the tier mapping.
#
# Profiles:
#   claude-acp  — Default. Keeps friendly shortnames (opus/sonnet/haiku).
#   anthropic   — Direct Anthropic API. Rewrites to full claude-* model IDs.
#   openai      — codex-acp via ChatGPT Pro/Max. opus→gpt-5.5, sonnet→gpt-5.3-codex, haiku→gpt-5.4-mini.
#
# Switching profiles only rewrites recipes. You also need to update
# ~/.config/goose/config.yaml GOOSE_PROVIDER and auth env vars for the new provider.
#
# Usage:
#   goose-profile                  (shows current; lists available)
#   goose-profile openai
#   goose-profile anthropic
#   goose-profile claude-acp
goose-profile() {
  local profile="${1:-}"
  local script="$HOME/IMA/dev/ima-goose/scripts/install.ts"
  if [ -z "$profile" ]; then
    echo "Available profiles: claude-acp (default), anthropic, openai"
    echo "Deployed recipes (first 5):"
    grep -h "^  goose_model:" "$HOME/.config/goose/recipes/"*.yaml 2>/dev/null | sort -u | head -5
    return 0
  fi
  node "$script" --profile "$profile"
}

# ── Session Management ────────────────────────────────────────────────────────
goose-resume() {
  local name="${1:?Usage: goose-resume <session-name>}"
  goose run --resume --name "$name"
}

goose-sessions() {
  goose session list
}

# ── Direct Recipe Shortcuts ───────────────────────────────────────────────────

goose-wp() {
  goose run --recipe wp-developer --name "wp-$(date +%Y%m%d-%H%M)" --interactive
}

goose-js() {
  goose run --recipe js-developer --name "js-$(date +%Y%m%d-%H%M)" --interactive
}

goose-explore() {
  goose run --recipe explore --name "explore-$(date +%Y%m%d-%H%M)" --interactive
}

goose-tests() {
  goose run --recipe test-writer --name "tests-$(date +%Y%m%d-%H%M)" --interactive
}

# ── Help ──────────────────────────────────────────────────────────────────────
goose-help() {
  cat <<'EOF'
IMA Goose Workflow Commands
────────────────────────────────────────────────────────
WORKFLOW (run in order per feature):

  goose-cycle [source]          Preferred full cycle: brainstorm → plan → story loop → document/learn
  goose-brainstorm [seed]       Phase 1 — interactive brainstorm, saves to Serena/file
  goose-plan [seed]             Phase 2 — interactive technical plan, saves to Serena/file
  goose-orchestrate [FNR-###]   Phase 2b — task-master: Epic→Story→Task + Jira + delegation
  goose-story-prompt FNR-123    Phase 3a — Jira story → implementation prompt (legacy)
  goose-implement FNR-123       Phase 3b — implementation prompt → code + PR
  goose-review [FNR-123]        Phase 4 — PR review, comment, Jira update

SESSION MANAGEMENT:

  goose-resume <session-name>   Resume a named session
  goose-sessions                List all sessions

DIRECT RECIPES:

  goose-wp                      WordPress development (ad hoc)
  goose-js                      JavaScript/TypeScript development (Svelte, Node, APIs, CLIs, TUIs)
  goose-explore                 Read-only codebase exploration
  goose-tests                   Write or debug tests

UPDATING RECIPES:

  node ~/IMA/dev/ima-goose/scripts/install.ts   Re-sync after pulling updates
  goose-profile                                 Show available model profiles
  goose-profile openai                          Switch recipes to GPT-5.x via codex-acp
  goose-profile claude-acp                      Switch recipes back to Claude (default)

DOCS:

  ~/IMA/dev/ima-goose/docs/WORKFLOW-MAPPING.md  — Full workflow guide
  ~/IMA/dev/ima-goose/shared/tool-guides/tea.md — Gitea CLI reference
────────────────────────────────────────────────────────
EOF
}
